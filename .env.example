NODE_ENV=development
PORT=4000

# MongoDB Atlas
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/studybuddy?retryWrites=true&w=majority

# Redis (Upstash)
REDIS_URL=redis://default:password@host:port

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-this-too
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Razorpay
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Resend (Email)
RESEND_API_KEY=re_...
FROM_EMAIL=hello@studybuddy.in

# Frontend URL (for CORS)
FRONTEND_URL=https://studybuddy.vercel.app
